# NewsMirror — Environment Variables
# Copy to .env.local for local dev, add to Vercel dashboard for production

# Supabase (get from: supabase.com → your project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Only used server-side (API routes / Edge Functions)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gemini (get from: aistudio.google.com → API Keys)
GEMINI_API_KEY=your-gemini-api-key-here
